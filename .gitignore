# Ignore generated site output and caches
_site/
.sass-cache/
.jekyll-cache/
.jekyll-metadata

# Ignore local development artifacts
local/
.worktrees/
node_modules/
package-lock.json
Gemfile.lock
/vendor/
vendor/bundle/
.bundle/

# Ignore editor files
.vscode/
.idea/
*.swp
*.swo

# Ignore OS files
.DS_Store
Thumbs.db

# Ignore local environment/config files
.env
.env.*
*.local
